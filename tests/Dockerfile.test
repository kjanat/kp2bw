FROM ghcr.io/astral-sh/uv:0.11.19-python3.14-trixie-slim

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl unzip nodejs \
    && rm -rf /var/lib/apt/lists/*

# Bun is the package manager for the Bitwarden CLI; the CLI itself runs on the
# apt-installed node.
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:/app/node_modules/.bin:$PATH"

WORKDIR /app

# Resolve @bitwarden/cli from the committed package.json + bun.lock (NOT @latest)
# so the version is pinned and reproducible -- the golden snapshots are a
# function of this exact CLI's JSON output, and Dependabot bumps it via the
# `bun` ecosystem. Copy the manifests first so this layer caches independently
# of source changes (bun-in-docker best practice).
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .
RUN uv sync --frozen

CMD ["uv", "run", "python", "tests/e2e_vaultwarden_test.py"]
